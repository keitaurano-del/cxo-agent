{
  "name": "apollo-server",
  "version": "0.1.0",
  "private": true,
  "description": "Apollo — 開発状況リアルタイム可視化ダッシュボードの backend (collectors + REST + SSE)",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
